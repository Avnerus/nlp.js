{
  "name": "nordic-design",
  "version": "4.27.0",
  "description": "Nordic Design Professor Chatbot - Create custom chatbots modeled after Nordic design professors",
  "author": "avnerus <avnerus@gmail.com>",
  "homepage": "https://github.com/Avnerus/nlp.js/tree/main/packages/nordic-design#readme",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Avnerus/nlp.js.git"
  },
  "vercel": {
    "builds": [
      { "src": "api/**/*.js", "use": "@vercel/node" },
      { "src": "public/**/*", "use": "@vercel/static" }
    ],
    "routes": [
      { "src": "/api/(.*)", "dest": "/api/$1" },
      { "src": "/(.*)", "dest": "/$1" }
    ]
  },
  "scripts": {
    "dev": "vercel dev",
    "build": "vercel build",
    "start": "vercel start"
  },
  "bugs": {
    "url": "https://github.com/Avnerus/nlp.js/issues"
  },
  "dependencies": {
    "@nlpjs/basic": "4.27.0",
    "@nlpjs/console-connector": "^4.26.1",
    "@nlpjs/core-loader": "^4.26.1",
    "@nlpjs/evaluator": "^4.26.1",
    "@nlpjs/lang-en": "^4.26.1",
    "@nlpjs/logger": "^4.26.1",
    "@nlpjs/nlp": "^4.27.0",
    "cors": "^2.8.5",
    "busboy": "^1.6.0"
  }
}
